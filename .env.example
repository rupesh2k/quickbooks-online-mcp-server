# QuickBooks Online API Credentials
# Get these from https://developer.intuit.com/

# Client ID from your Intuit Developer app
QUICKBOOKS_CLIENT_ID=your_client_id_here

# Client Secret from your Intuit Developer app
QUICKBOOKS_CLIENT_SECRET=your_client_secret_here

# Environment: 'sandbox' for testing, 'production' for live data
QUICKBOOKS_ENVIRONMENT=sandbox

# Redirect URI for OAuth callback (must match Intuit Developer Portal)
QUICKBOOKS_REDIRECTURI=http://localhost:8000/callback

# OAuth Refresh Token (obtained after authentication)
QUICKBOOKS_REFRESH_TOKEN=your_refresh_token_here

# Realm ID (Company ID) from QuickBooks
QUICKBOOKS_REALM_ID=your_realm_id_here

# Optional: Node environment
NODE_ENV=development
